<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>InspectPro — Subscribe</title>
<script src="https://js.stripe.com/v3/"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Mulish:wght@400;600;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Mulish',sans-serif;background:#1a1a2e;color:#fff;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;}
.page-logo{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:#e8ff47;margin-bottom:6px;text-align:center;}
.page-logo span{color:#fff;}
.page-sub{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:32px;text-align:center;letter-spacing:.5px;text-transform:uppercase;}
.payment-card{background:#252540;border:1px solid rgba(232,255,71,.15);border-radius:20px;padding:32px;width:100%;max-width:440px;}
.plan-toggle{display:flex;background:rgba(255,255,255,.06);border-radius:12px;padding:4px;margin-bottom:24px;}
.plan-opt{flex:1;padding:10px;border:none;border-radius:9px;background:transparent;color:rgba(255,255,255,.4);font-family:'Mulish',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;}
.plan-opt.active{background:#e8ff47;color:#1a1a2e;}
.price-display{text-align:center;margin-bottom:24px;}
.price-amount{font-family:'Syne',sans-serif;font-size:48px;font-weight:800;color:#e8ff47;line-height:1;}
.price-period{font-size:14px;color:rgba(255,255,255,.4);margin-top:4px;}
.price-save{display:inline-block;background:rgba(34,214,122,.15);color:#22d67a;font-size:11px;font-weight:800;padding:3px 10px;border-radius:20px;border:1px solid rgba(34,214,122,.25);margin-top:8px;}
.features{margin-bottom:24px;}
.feature-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:13px;color:rgba(255,255,255,.7);}
.feature-row:last-child{border-bottom:none;}
.feature-row .ficon{font-size:16px;flex-shrink:0;}
.divider{height:1px;background:rgba(255,255,255,.08);margin-bottom:20px;}
.field-label{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.35);display:block;margin-bottom:6px;}
.field-input{width:100%;background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 14px;color:#fff;font-family:'Mulish',sans-serif;font-size:14px;outline:none;transition:border-color .18s;margin-bottom:14px;}
.field-input:focus{border-color:rgba(232,255,71,.4);}
.field-input::placeholder{color:rgba(255,255,255,.25);}
.stripe-element-wrap{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:14px;margin-bottom:14px;transition:border-color .18s;}
.stripe-element-wrap.focused{border-color:rgba(232,255,71,.4);}
.pay-btn{width:100%;padding:16px;border:none;border-radius:12px;background:#e8ff47;color:#1a1a2e;font-family:'Syne',sans-serif;font-size:18px;font-weight:800;cursor:pointer;transition:all .2s;position:relative;}
.pay-btn:hover{opacity:.9;transform:translateY(-1px);}
.pay-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.pay-btn .spinner{display:none;width:20px;height:20px;border:3px solid rgba(26,26,46,.3);border-top-color:#1a1a2e;border-radius:50%;animation:spin .6s linear infinite;position:absolute;right:20px;top:50%;margin-top:-10px;}
.pay-btn.loading .spinner{display:block;}
.pay-btn.loading .btn-text{opacity:.5;}
@keyframes spin{to{transform:rotate(360deg)}}
.secure-note{display:flex;align-items:center;justify-content:center;gap:6px;font-size:11px;color:rgba(255,255,255,.25);margin-top:14px;}
.error-msg{background:rgba(255,59,59,.1);border:1px solid rgba(255,59,59,.25);border-radius:8px;padding:10px 14px;font-size:13px;color:#ff6b6b;margin-bottom:14px;display:none;}
.success-screen{display:none;text-align:center;padding:20px 0;}
.success-icon{font-size:64px;margin-bottom:16px;}
.success-title{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:#e8ff47;margin-bottom:8px;}
.success-body{font-size:14px;color:rgba(255,255,255,.5);line-height:1.7;margin-bottom:24px;}
.back-btn{display:inline-block;padding:12px 28px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);border-radius:10px;color:#fff;font-family:'Mulish',sans-serif;font-size:14px;font-weight:700;text-decoration:none;cursor:pointer;}
.back-btn:hover{background:rgba(255,255,255,.14);}
.test-notice{background:rgba(255,184,0,.08);border:1px solid rgba(255,184,0,.2);border-radius:8px;padding:10px 14px;font-size:12px;color:#ffb800;margin-bottom:16px;text-align:center;}
</style>
</head>
<body>

<div class="page-logo">Inspect<span>Pro</span></div>
<div class="page-sub">Premium Membership</div>

<div class="payment-card">

  <!-- SUCCESS STATE -->
  <div class="success-screen" id="success-screen">
    <div class="success-icon">🎉</div>
    <div class="success-title">You're Premium!</div>
    <div class="success-body">
      Your account has been upgraded.<br>
      You now earn points on every accepted job,<br>
      get free inspections, and full vehicle history.
    </div>
    <a href="index.html" class="back-btn">← Go to InspectPro</a>
  </div>

  <!-- PAYMENT FORM -->
  <div id="payment-form">

    <!-- TEST MODE NOTICE — remove when going live -->
    <div class="test-notice">
      🧪 Test Mode — Use card <strong>4242 4242 4242 4242</strong>, any future date, any CVC
    </div>

    <!-- Plan toggle -->
    <div class="plan-toggle">
      <button class="plan-opt active" id="opt-monthly" onclick="setPlan('monthly')">Monthly</button>
      <button class="plan-opt" id="opt-yearly" onclick="setPlan('yearly')">Yearly</button>
    </div>

    <!-- Price display -->
    <div class="price-display">
      <div class="price-amount" id="price-amount">$9.99</div>
      <div class="price-period" id="price-period">per month · cancel anytime</div>
      <div class="price-save" id="price-save" style="display:none">Save $23.89/year</div>
    </div>

    <!-- Features -->
    <div class="features">
      <div class="feature-row"><span class="ficon">🏆</span>Earn 100 points per accepted job</div>
      <div class="feature-row"><span class="ficon">🔍</span>Free inspection at 300 points</div>
      <div class="feature-row"><span class="ficon">🛢️</span>Free oil change at 500 points</div>
      <div class="feature-row"><span class="ficon">📋</span>Full vehicle inspection history</div>
      <div class="feature-row"><span class="ficon">⚡</span>Priority technician response</div>
      <div class="feature-row"><span class="ficon">🚗</span>Multiple vehicles on one account</div>
    </div>

    <div class="divider"></div>

    <!-- Customer info -->
    <label class="field-label">Your Name</label>
    <input class="field-input" id="customer-name" placeholder="John Smith" type="text">

    <label class="field-label">Email Address</label>
    <input class="field-input" id="customer-email" placeholder="you@email.com" type="email">

    <!-- Card element -->
    <label class="field-label">Card Details</label>
    <div class="stripe-element-wrap" id="card-element-wrap">
      <div id="card-element"></div>
    </div>

    <!-- Error message -->
    <div class="error-msg" id="error-msg"></div>

    <!-- Pay button -->
    <button class="pay-btn" id="pay-btn" onclick="handlePayment()">
      <span class="btn-text" id="btn-text">Subscribe — $9.99/mo</span>
      <div class="spinner"></div>
    </button>

    <div class="secure-note">🔒 Secured by Stripe · Never stored on our servers</div>

  </div>
</div>

<script>
// ══════════════════════════════════════════
// REPLACE THIS WITH YOUR STRIPE PUBLISHABLE KEY
// Get it from: stripe.com → Developers → API Keys
// It starts with pk_test_ (test) or pk_live_ (live)
// ══════════════════════════════════════════
const STRIPE_PUBLISHABLE_KEY = 'pk_test_REPLACE_WITH_YOUR_KEY';

// ══════════════════════════════════════════
// REPLACE THESE WITH YOUR STRIPE PRICE IDs
// Create them in: stripe.com → Products → Add Product
// ══════════════════════════════════════════
const PRICE_IDS = {
  monthly: 'price_REPLACE_WITH_MONTHLY_PRICE_ID',
  yearly: 'price_REPLACE_WITH_YEARLY_PRICE_ID'
};

// ══════════════════════════════════════════
// REPLACE WITH YOUR SUPABASE EDGE FUNCTION URL
// You'll create this in Supabase (instructions below)
// ══════════════════════════════════════════
const PAYMENT_ENDPOINT = 'https://YOUR_PROJECT.supabase.co/functions/v1/create-payment';

// ──────────────────────────────────────────
let currentPlan = 'monthly';
const stripe = Stripe(STRIPE_PUBLISHABLE_KEY);
const elements = stripe.elements({
  appearance: {
    theme: 'night',
    variables: {
      colorPrimary: '#e8ff47',
      colorBackground: 'rgba(255,255,255,0.07)',
      colorText: '#ffffff',
      colorDanger: '#ff3b3b',
      fontFamily: 'Mulish, sans-serif',
      borderRadius: '8px',
    }
  }
});

const cardElement = elements.create('card', {
  style: {
    base: {
      fontSize: '14px',
      color: '#ffffff',
      '::placeholder': { color: 'rgba(255,255,255,0.3)' }
    }
  }
});
cardElement.mount('#card-element');

cardElement.on('focus', () => document.getElementById('card-element-wrap').classList.add('focused'));
cardElement.on('blur', () => document.getElementById('card-element-wrap').classList.remove('focused'));

function setPlan(plan) {
  currentPlan = plan;
  document.getElementById('opt-monthly').classList.toggle('active', plan === 'monthly');
  document.getElementById('opt-yearly').classList.toggle('active', plan === 'yearly');
  document.getElementById('price-amount').textContent = plan === 'monthly' ? '$9.99' : '$95.99';
  document.getElementById('price-period').textContent = plan === 'monthly' ? 'per month · cancel anytime' : 'per year · save $23.89';
  document.getElementById('price-save').style.display = plan === 'yearly' ? 'inline-block' : 'none';
  document.getElementById('btn-text').textContent = plan === 'monthly' ? 'Subscribe — $9.99/mo' : 'Subscribe — $95.99/yr';
}

function showError(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = msg;
  el.style.display = 'block';
}

function hideError() {
  document.getElementById('error-msg').style.display = 'none';
}

function setLoading(on) {
  const btn = document.getElementById('pay-btn');
  btn.classList.toggle('loading', on);
  btn.disabled = on;
}

async function handlePayment() {
  hideError();
  const name = document.getElementById('customer-name').value.trim();
  const email = document.getElementById('customer-email').value.trim();

  if (!name) { showError('Please enter your name.'); return; }
  if (!email) { showError('Please enter your email.'); return; }
  if (!email.includes('@')) { showError('Please enter a valid email address.'); return; }

  setLoading(true);

  try {
    // Step 1 — Create a PaymentMethod from the card details
    const { paymentMethod, error: pmError } = await stripe.createPaymentMethod({
      type: 'card',
      card: cardElement,
      billing_details: { name, email }
    });

    if (pmError) {
      showError(pmError.message);
      setLoading(false);
      return;
    }

    // Step 2 — Send to your backend (Supabase Edge Function)
    // This creates the Stripe customer + subscription on the server
    const response = await fetch(PAYMENT_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        paymentMethodId: paymentMethod.id,
        priceId: PRICE_IDS[currentPlan],
        name, email, plan: currentPlan
      })
    });

    const result = await response.json();

    if (!response.ok || result.error) {
      showError(result.error || 'Payment failed. Please try again.');
      setLoading(false);
      return;
    }

    // Step 3 — Handle 3D Secure if required by the bank
    if (result.requiresAction) {
      const { error: actionError } = await stripe.confirmCardPayment(result.clientSecret);
      if (actionError) {
        showError(actionError.message);
        setLoading(false);
        return;
      }
    }

    // Step 4 — Success
    document.getElementById('payment-form').style.display = 'none';
    document.getElementById('success-screen').style.display = 'block';

    // Mark user as premium in localStorage so the app knows
    try {
      const profiles = JSON.parse(localStorage.getItem('ip_cust_profiles') || '[]');
      const idx = profiles.findIndex(p => p.username === email || p.name === name);
      if (idx >= 0) {
        profiles[idx].isPremium = true;
        profiles[idx].premiumSince = new Date().toISOString();
        profiles[idx].points = profiles[idx].points || 0;
        localStorage.setItem('ip_cust_profiles', JSON.stringify(profiles));
      }
    } catch(e) {}

  } catch(err) {
    showError('Something went wrong. Please try again.');
    setLoading(false);
  }
}
</script>
</body>
</html>
